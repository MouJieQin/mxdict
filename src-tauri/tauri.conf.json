{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FstDict",
  "version": "0.0.8",
  "identifier": "FstDict",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:9595",
    "beforeBuildCommand": "npm run build:all",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "",
        "width": 1440,
        "height": 900,
        "dragDropEnabled": true,
        "titleBarStyle": "Overlay"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "resources": [
      "sidecars/**/*"
    ],
    "externalBin": [],
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
